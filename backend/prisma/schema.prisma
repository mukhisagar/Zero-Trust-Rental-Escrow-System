generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String @id @default(cuid())
  email     String @unique
  passwordHash String
  role      String @default("LANDLORD")
  createdAt DateTime @default(now())

  properties Property[]
  escrows    Escrow[]
}

model Property {
  id            String   @id @default(cuid())
  title         String
  description   String
  depositAmount Float
  landlordId    String
  landlord      User     @relation(fields: [landlordId], references: [id])
  createdAt     DateTime @default(now())
  escrows       Escrow[]

  @@unique([landlordId, title])
}

model Escrow {
  id           String @id @default(cuid())
  propertyId   String
  tenantId     String?
  property     Property @relation(fields: [propertyId], references: [id])
  tenant       User?    @relation(fields: [tenantId], references: [id])
  status       String @default("PENDING")
  paidAmount   Float?
  landlordConfirmed Boolean @default(false)
  tenantConfirmed Boolean @default(false)
  released     Boolean @default(false)
  createdAt    DateTime @default(now())
}

